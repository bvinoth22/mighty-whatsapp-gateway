# ── MightyVision WhatsApp Gateway ──────────────────────────────
# Copy to .env and fill in. Nothing here touches the existing apps.

# HTTP server (setup page + pairing endpoints)
PORT=3000

# Which messaging engine to use. Only "baileys" is implemented in Phase 1.
# The adapter interface lets us add "cloud" (WhatsApp Cloud API) later
# without touching the rest of the code.
PROVIDER=baileys

# The private group to monitor. Leave blank to monitor ALL groups the
# linked account belongs to (handy while testing). You can also match by name.
TARGET_GROUP_NAME=Mighty-Wing Aviaries
TARGET_GROUP_JID=

# Dedicated bot number used for pairing-code login (digits only, with country
# code, e.g. 91XXXXXXXXXX). Used so you type an 8-digit code instead of scanning.
BOT_PHONE_NUMBER=

# ── MightyVisionWeb API (operations / data) ────────────────────
# The gateway calls this API with an X-User-ID header. All business logic and
# data isolation already live there. Do NOT put the Supabase service key here.
MIGHTY_API_URL=http://localhost:3001

# ── Supabase (identity + subscription + session storage) ───────
# Used read-only for: resolve sender phone -> userId, check subscription,
# and to persist the Baileys session (no SQLite, no session files).
# If left blank, the gateway runs in DEV mode: in-memory session + a
# configurable dev tenant (below) so you can test without network access.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── DEV fallback (only used when SUPABASE_URL is blank) ─────────
# Lets you test the full flow offline. Maps any sender to this tenant.
DEV_FALLBACK_USER_ID=U_1
DEV_FALLBACK_SUBSCRIPTION_ACTIVE=true

# Subscription gate: when true, only an explicit feature_subscriptions row
# (feature='whatsapp_bot') grants access. When false, an active species
# subscription also counts.
STRICT_SUBSCRIPTION=false

# Default species scope for lookups
SPECIES_ID=S_1

LOG_LEVEL=info
