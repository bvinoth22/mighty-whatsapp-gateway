{
  "name": "mighty-whatsapp-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant WhatsApp gateway for MightyVision. Resolves a sender phone to a subscriber, gates on subscription, and answers keyword commands with only that tenant's data via the MightyVisionWeb API.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "@supabase/supabase-js": "^2.45.4",
    "baileys": "^6.7.9",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "node-cron": "^4.5.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
